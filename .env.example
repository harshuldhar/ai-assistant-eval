# ─────────────────────────────────────────────────────────────────
# AI Assistant Eval — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to Git.
# ─────────────────────────────────────────────────────────────────

# ─── Frontier Model: Gemini 2.0 Flash ────────────────────────────
# Get your free key at: https://aistudio.google.com → "Get API Key"
GOOGLE_API_KEY=your_google_ai_studio_key_here

# ─── OSS Model: Qwen2.5-0.5B via HuggingFace Inference API ───────
# Get your token at: https://huggingface.co/settings/tokens
# Create a token with "Write" role (needed for Spaces deployment too)
HF_TOKEN=your_hf_token_here

# ─── Model IDs (defaults, change only if you want a different model) ───
HF_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct
FRONTIER_MODEL=gemini-2.0-flash

# ─── Bonus: HF Spaces public URL (fill in after deployment) ───────
HF_SPACE_URL=https://YOUR_USERNAME-ai-assistant-eval.hf.space
